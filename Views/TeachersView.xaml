<UserControl x:Class="UniversityMenuApp.Views.TeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Height="452" Width="559">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Mantenimiento de Maestros" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,179"/>
        </StackPanel>
        <TextBox Text="{Binding formName}" HorizontalAlignment="Left" Height="15" Margin="238,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="133"/>
        <TextBox Text="{Binding formEmail}" HorizontalAlignment="Left" Height="16" Margin="238,158,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="133"/>
        <DataGrid Grid.Column="0"
                  HorizontalAlignment="Left" 
                  Height="148" 
                  Margin="0,93,0,0" 
                  VerticalAlignment="Top" 
                  Width="225" 
                  ItemsSource="{Binding Teachers}"
                  SelectedItem="{Binding SelectedTeacher}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Nombre" HorizontalAlignment="Left" Margin="238,93,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label Content="Email" HorizontalAlignment="Left" Margin="238,140,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Button Content="Eliminar" HorizontalAlignment="Left" Margin="403,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        <Button Content="Modificar" HorizontalAlignment="Left" Margin="312,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        <Button Content="Agregar" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" Margin="245,0,0,0"/>
        <Button Content="Export to Excel" HorizontalAlignment="Left" Margin="266,224,0,0" VerticalAlignment="Top" FontWeight="Bold" Height="24" Width="179" Background="#FF19F309" Command="{Binding ExportToExcelCommand}"/>
    </Grid>
</UserControl>
